{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mauroprime.local/schemas/skill-routing.schema.json",
  "title": "MauroPrime Skill Routing",
  "type": "object",
  "required": ["schemaVersion", "skills", "workflows"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "skills": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/skillRoute" }
    },
    "workflows": {
      "type": "array",
      "items": { "$ref": "#/$defs/workflow" }
    }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domains": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "artifacts": { "type": "array", "items": { "type": "string" } },
        "needs": { "type": "array", "items": { "type": "string" } },
        "signals": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "enum": ["read-only", "write", "destructive", "external-side-effect"] } },
        "stages": { "type": "array", "items": { "enum": ["start", "implement", "verify", "persist", "close", "resume"] } }
      }
    },
    "skillRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phase": { "enum": ["discovery", "safety", "implementation", "verification", "persistence", "maintenance"] },
        "coversPhases": { "type": "array", "items": { "enum": ["discovery", "safety", "implementation", "verification", "persistence", "maintenance"] }, "uniqueItems": true },
        "domains": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "artifacts": { "type": "array", "items": { "type": "string" } },
        "needs": { "type": "array", "items": { "type": "string" } },
        "signals": { "type": "array", "items": { "type": "string" } },
        "requires": { "type": "array", "items": { "type": "string" } },
        "complements": { "type": "array", "items": { "type": "string" } },
        "excludes": { "type": "array", "items": { "type": "string" } },
        "negativeIntents": { "type": "array", "items": { "type": "string" } },
        "requireNeedMatch": { "type": "boolean", "default": false },
        "requireActionMatch": { "type": "boolean", "default": false },
        "priority": { "type": "integer", "minimum": 0, "maximum": 100 },
        "activation": { "enum": ["on-demand", "always", "closing"] }
      }
    },
    "workflowPhase": {
      "type": "object",
      "required": ["phase", "skills"],
      "additionalProperties": false,
      "properties": {
        "phase": { "enum": ["discovery", "safety", "implementation", "verification", "persistence", "maintenance"] },
        "skills": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "required": { "type": "boolean", "default": true },
        "when": { "$ref": "#/$defs/condition" }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["name", "match", "phases"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "match": { "$ref": "#/$defs/condition" },
        "phases": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/workflowPhase" } }
      }
    }
  }
}
