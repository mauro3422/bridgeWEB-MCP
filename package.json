{
  "name": "bridge-mcp",
  "version": "0.6.6",
  "description": "Kairos/KChat local MCP bridge for MauroPrime and future laptop agents.",
  "type": "module",
  "bin": {
    "bridge-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "start:http": "node dist/http.js",
    "check": "tsc --noEmit",
    "smoke:http": "powershell -NoProfile -File .\\scripts\\test-bridge-http.ps1",
    "test:regressions": "powershell -NoProfile -File .\\scripts\\test-bridge-regressions.ps1 && node scripts/test-v060-tools.mjs && node scripts/test-whiteboard-tools.mjs",
    "test:skill-routing": "npm run build && node scripts/test-skill-routing.mjs",
    "test:whiteboard": "npm run build && node scripts/test-whiteboard-tools.mjs",
    "verify:all": "powershell -NoProfile -File .\\scripts\\verify-all.ps1",
    "docs:tools": "npm run build && node scripts/generate-tools-doc.mjs",
    "docs:tools:check": "npm run build && node scripts/generate-tools-doc.mjs --check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "zod": "^3.24.1"
  },
  "overrides": {
    "@hono/node-server": "2.0.11"
  },

  "devDependencies": {
    "@types/node": "^20.17.24",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
